router bgp {{ asn }}
    bgp router-id {{ router_id }}
{% for nbr in neighbors %}
    neighbor {{ nbr.ip }} remote-as {{ nbr.asn }}
{% if nbr.asn == asn %}
    neighbor {{ nbr.ip }} next-hop-self
{% endif %}
{% endfor %}

{% for net in networks %}
    network {{ net.ip }} mask {{ net.mask}}
{% endfor %}